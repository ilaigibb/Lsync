#!/bin/bash

set -e

VERSION="1.0.0"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

DEFAULT_HOST="129.159.130.127"
DEFAULT_USER="ubuntu"
DEFAULT_SSH_KEY="$HOME/.ssh/id_rsa.key"
DEFAULT_REMOTE_PATH=".lodestone"
DEFAULT_LOCAL_PATH="$HOME/localServer"
DEFAULT_BACKUP_DIR="$HOME/.lsync_backups"
DEFAULT_PUSH_CMD="dpush"
DEFAULT_PULL_CMD="dpull"

HOST="$DEFAULT_HOST"
USER="$DEFAULT_USER"
SSH_KEY="$DEFAULT_SSH_KEY"
REMOTE_PATH="$DEFAULT_REMOTE_PATH"
LOCAL_PATH="$DEFAULT_LOCAL_PATH"
BACKUP_DIR="$DEFAULT_BACKUP_DIR"
PUSH_CMD="$DEFAULT_PUSH_CMD"
PULL_CMD="$DEFAULT_PULL_CMD"

QUIET=false
AUTO_YES=false
DEBUG=false
DRY_RUN=false
DELETE_FLAG=false

CONFIG_FILE="$HOME/.lsyncrc"

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
}

init_config() {
    echo -e "${CYAN}=== First Time Setup ===${NC}"
    echo ""
    
    echo -n "Enter SSH Host [$DEFAULT_HOST]: "
    read -r host_input
    HOST="${host_input:-$DEFAULT_HOST}"
    
    echo -n "Enter SSH User [$DEFAULT_USER]: "
    read -r user_input
    USER="${user_input:-$DEFAULT_USER}"
    
    echo -n "SSH Key Path [$DEFAULT_SSH_KEY]: "
    read -r key_input
    SSH_KEY="${key_input:-$DEFAULT_SSH_KEY}"
    
    echo -n "Local Path [$DEFAULT_LOCAL_PATH]: "
    read -r local_input
    LOCAL_PATH="${local_input:-$DEFAULT_LOCAL_PATH}"
    
    echo -n "Remote Path [$DEFAULT_REMOTE_PATH]: "
    read -r remote_input
    REMOTE_PATH="${remote_input:-$DEFAULT_REMOTE_PATH}"
    
    echo -n "Backup Directory [$DEFAULT_BACKUP_DIR]: "
    read -r backup_input
    BACKUP_DIR="${backup_input:-$DEFAULT_BACKUP_DIR}"
    
    echo -n "Push Command Name [$DEFAULT_PUSH_CMD]: "
    read -r push_input
    PUSH_CMD="${push_input:-$DEFAULT_PUSH_CMD}"
    
    echo -n "Pull Command Name [$DEFAULT_PULL_CMD]: "
    read -r pull_input
    PULL_CMD="${pull_input:-$DEFAULT_PULL_CMD}"
    
    mkdir -p "$(dirname "$CONFIG_FILE")"
    
    cat > "$CONFIG_FILE" << EOF
# lsync configuration
# Generated by lsync init

HOST="$HOST"
USER="$USER"
SSH_KEY="$SSH_KEY"
REMOTE_PATH="$REMOTE_PATH"
LOCAL_PATH="$LOCAL_PATH"
BACKUP_DIR="$BACKUP_DIR"
PUSH_CMD="$PUSH_CMD"
PULL_CMD="$PULL_CMD"
EOF

    echo ""
    echo -e "${GREEN}Config saved to $CONFIG_FILE${NC}"
    echo ""
    echo "You can edit this file anytime or run 'lsync init --reset' to reconfigure."
}

show_help() {
    echo "lsync v$VERSION - File synchronization tool"
    echo ""
    echo "Usage: lsync [options] <command> [folder]"
    echo ""
    echo "Options:"
    echo "  -y, --yes      Auto-confirm prompts"
    echo "  -q, --quiet    Suppress non-error output"
    echo "  --debug        Show raw rsync output"
    echo "  --dry-run      Preview changes without syncing"
    echo "  --delete       Remove files not in source"
    echo ""
    echo "Commands:"
    echo "  $PUSH_CMD           Push $REMOTE_PATH to server"
    echo "  $PULL_CMD          Pull $REMOTE_PATH from server"
    echo "  push [folder]      Push current directory to server"
    echo "  pull [folder]      Pull current directory from server"
    echo "  backup             List available backups"
    echo "  restore <name>     Restore from backup"
    echo "  init               Configure lsync"
    echo "  init --reset       Reset configuration"
    echo "  --version          Show version"
    echo ""
    echo "Config file: $CONFIG_FILE"
}

parse_flags() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -q|--quiet) QUIET=true; shift ;;
            -y|--yes) AUTO_YES=true; shift ;;
            --debug) DEBUG=true; shift ;;
            --dry-run) DRY_RUN=true; shift ;;
            --delete) DELETE_FLAG=true; shift ;;
            -h|--help)
                show_help
                exit 0
                ;;
            --version)
                echo "lsync v$VERSION"
                exit 0
                ;;
            -*)
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    
    CMD_ACTION="${1:-}"
    CMD_ARG="${2:-}"
}

RSYNC_PREVIEW_OPTS="-avzn --out-format=%i%n"
RSYNC_OPTS="-avz --progress"

if [[ "$DELETE_FLAG" == true ]]; then
    RSYNC_OPTS="$RSYNC_OPTS --delete"
fi

if [[ "$DRY_RUN" == true ]]; then
    RSYNC_PREVIEW_OPTS="$RSYNC_PREVIEW_OPTS -n"
fi

get_changes() {
    local src="$1"
    local dst="$2"
    local quiet="${3:-false}"
    
    local added=0
    local deleted=0
    local files=()
    
    if [[ "$DEBUG" == true ]]; then
        echo "Running: rsync $RSYNC_PREVIEW_OPTS -e \"ssh -i $SSH_KEY -o StrictHostKeyChecking=no\" \"$src/\" \"$dst/\""
    fi
    
    rsync_output=$(rsync $RSYNC_PREVIEW_OPTS -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" "$src/" "$dst/" 2>&1)
    
    if [[ "$DEBUG" == true ]]; then
        echo "--- RSYNC OUTPUT START ---"
        echo "$rsync_output"
        echo "--- RSYNC OUTPUT END ---"
    fi
    
    rsync_output=$(echo "$rsync_output" | grep -v '^sending' | grep -v '^receiving' | grep -v '^total:' | grep -v '^Number of' | grep -v '^--' | grep -v '^sent ' | grep -v '^total ')
    
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        indicator="${line:0:1}"
        [[ "$indicator" != ">" && "$indicator" != "<" && "$indicator" != "c" && "$indicator" != "d" ]] && continue
        filename="${line:11}"
        
        [[ -z "$filename" ]] && continue
        
        local is_dir=false
        if [[ "$filename" == */ ]]; then
            is_dir=true
            filename="${filename%/}"
        fi
        
        if [[ "$indicator" == "<" ]]; then
            ((deleted++))
            if [[ "$is_dir" == true ]]; then
                files+=("-${filename}/")
            else
                files+=("-${filename}")
            fi
        elif [[ "$indicator" == ">" || "$indicator" == "c" ]]; then
            ((added++))
            if [[ "$is_dir" == true ]]; then
                files+=("+${filename}/")
            else
                files+=("+${filename}")
            fi
        fi
    done <<< "$rsync_output"
    
    if [[ $added -eq 0 && $deleted -eq 0 ]]; then
        return 1
    fi
    
    if [[ "$quiet" == "true" || "$QUIET" == "true" ]]; then
        return 0
    fi
    
    echo -e "${GREEN}+$added${NC} ${RED}-$deleted${NC}:"
    for f in "${files[@]}"; do
        if [[ "$f" == -* ]]; then
            printf "${RED}$f${NC}\n" "${f:1}"
        else
            printf "${GREEN}$f${NC}\n"
        fi
    done
    
    return 0
}

confirm() {
    if [[ "$AUTO_YES" == true ]]; then
        return 0
    fi
    
    local prompt="$1"
    while true; do
        read -p "$prompt [y/n] " 
        case "$REPLY" in
            y|Y) return 0 ;;
            n|N) return 1 ;;
        esac
    done
}

backup_create() {
    local src="$1"
    local name="$2"
    local backup_path="$BACKUP_DIR/${name}_$(date +%Y%m%d_%H%M%S)"
    
    mkdir -p "$BACKUP_DIR"
    if [[ "$QUIET" != "true" ]]; then
        echo "Creating backup: $backup_path"
    fi
    if ! rsync -avq "$src" "$backup_path/" 2>/dev/null; then
        echo -e "${RED}Error: Backup failed${NC}" >&2
        return 1
    fi
    if [[ "$QUIET" != "true" ]]; then
        echo "Backup created: $backup_path"
    fi
    echo "$backup_path" > "$BACKUP_DIR/latest_$name"
}

backup_restore() {
    local name="$1"
    local backup_path
    
    if [[ -z "$name" ]]; then
        echo "Usage: $0 restore <backup_name>"
        return 1
    fi
    
    if [[ -f "$BACKUP_DIR/$name" ]]; then
        backup_path=$(cat "$BACKUP_DIR/$name")
    else
        backup_path="$BACKUP_DIR/$name"
    fi
    
    if [[ ! -d "$backup_path" ]]; then
        echo "Backup not found: $backup_path"
        return 1
    fi
    
    echo "Backup: $backup_path"
    ls -la "$backup_path"
    
    if confirm "Restore this backup?"; then
        echo "Restore functionality coming soon"
    else
        echo "Restore cancelled."
    fi
}

backup_list() {
    echo "Available backups:"
    ls -lt "$BACKUP_DIR" 2>/dev/null | head -20
}

run_rsync_progress() {
    local src="$1"
    local dst="$2"
    
    local total_files
    total_files=$(rsync -av --stats -n "$src" "$dst" 2>&1 | grep -E "Number of regular files transferred" | awk '{print $NF}' | tr -d ',')
    [[ -z "$total_files" ]] && total_files=0
    
    if [[ $total_files -eq 0 ]]; then
        if [[ "$QUIET" != "true" ]]; then
            echo -e "${CYAN}Syncing...${NC}"
        fi
        if ! rsync -avz -q -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" "$src" "$dst" 2>&1; then
            echo -e "${RED}Error: Sync failed${NC}" >&2
            return 1
        fi
        if [[ "$QUIET" != "true" ]]; then
            echo -e "${GREEN}Done!${NC}"
        fi
        return
    fi
    
    if [[ "$DEBUG" == true ]]; then
        rsync -avz -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" "$src" "$dst"
        return
    fi
    
    local current=0
    local bar_width=40
    local rsync_exit_code=0
    
    while IFS= read -r line; do
        first_char="${line:0:1}"
        if [[ "$first_char" == ">" || "$first_char" == "<" || "$first_char" == "c" ]]; then
            ((current++))
            filename=$(echo "$line" | awk '{for(i=5;i<=NF;i++) printf "%s ", $i}' | sed 's/ *$//')
            [[ -z "$filename" ]] && filename="transferring..."
            
            pct=$((current * 100 / total_files))
            filled=$((pct * bar_width / 100))
            empty=$((bar_width - filled))
            
            printf "\r[${GREEN}%-${filled}s${RED}%-${empty}s${NC}] %3d%% | %d/%d | %s" \
                "$(printf '#%.0s' $(seq 1 $filled) 2>/dev/null)" \
                "$(printf '.%.0s' $(seq 1 $empty) 2>/dev/null)" \
                "$pct" "$current" "$total_files" "$filename"
        fi
    done < <(rsync -avz -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" "$src" "$dst" 2>&1 | grep -v '^sending' | grep -v '^receiving' | grep -v '^total:')
    
    rsync_exit_code=${PIPESTATUS[0]}
    echo ""
    
    if [[ $rsync_exit_code -ne 0 ]]; then
        echo -e "${RED}Error: Sync failed with exit code $rsync_exit_code${NC}" >&2
        return 1
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        echo -e "${GREEN}Done!${NC}"
    fi
}

sync_push() {
    local folder="$1"
    local cwd="$(pwd)"
    local local_dir
    local remote_dir
    local backup_name
    
    if [[ -z "$folder" ]]; then
        local_dir="$cwd"
        remote_dir="$cwd"
        backup_name="$(basename "$cwd")"
    else
        local_dir="$cwd/$folder"
        remote_dir="$cwd/$folder"
        backup_name="$(basename "$folder")"
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        echo -e "${CYAN}Checking...${NC}"
    fi
    
    if ! get_changes "$local_dir/" "$USER@$HOST:$remote_dir/" "true"; then
        if [[ "$QUIET" != "true" ]]; then
            echo -e "${GREEN}Nothing to commit${NC}"
        fi
        return
    fi
    
    get_changes "$local_dir/" "$USER@$HOST:$remote_dir/" "$QUIET"
    
    if confirm "Are you sure you want to commit those changes?"; then
        if [[ "$QUIET" != "true" ]]; then
            echo "Creating backup of server destination..."
        fi
        backup_create "$USER@$HOST:$remote_dir/" "$backup_name"
        
        run_rsync_progress "$local_dir/" "$USER@$HOST:$remote_dir/"
        if [[ "$QUIET" != "true" ]]; then
            echo -e "${GREEN}Done!${NC}"
        fi
    else
        echo "Push cancelled."
    fi
}

sync_pull() {
    local folder="$1"
    local cwd="$(pwd)"
    local local_dir
    local remote_dir
    local backup_name
    
    if [[ -z "$folder" ]]; then
        local_dir="$cwd"
        remote_dir="$cwd"
        backup_name="$(basename "$cwd")"
    else
        local_dir="$cwd/$folder"
        remote_dir="$cwd/$folder"
        backup_name="$(basename "$folder")"
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        echo -e "${CYAN}Checking...${NC}"
    fi
    
    if ! get_changes "$USER@$HOST:$remote_dir/" "$local_dir/" "true"; then
        if [[ "$QUIET" != "true" ]]; then
            echo -e "${GREEN}Nothing to commit${NC}"
        fi
        return
    fi
    
    get_changes "$USER@$HOST:$remote_dir/" "$local_dir/" "$QUIET"
    
    if confirm "Are you sure you want to commit those changes?"; then
        if [[ "$QUIET" != "true" ]]; then
            echo "Creating backup of local destination..."
        fi
        backup_create "$local_dir/" "$backup_name"
        
        run_rsync_progress "$USER@$HOST:$remote_dir/" "$local_dir/"
        if [[ "$QUIET" != "true" ]]; then
            echo -e "${GREEN}Done!${NC}"
        fi
    else
        echo "Pull cancelled."
    fi
}

sync_default() {
    local action="$1"
    local local_dir="$LOCAL_PATH/$REMOTE_PATH"
    local remote_dir="$REMOTE_PATH"
    
    if [[ "$QUIET" != "true" ]]; then
        echo -e "${CYAN}Checking...${NC}"
    fi
    
    if [[ "$action" == "push" ]]; then
        if ! get_changes "$local_dir/" "$USER@$HOST:$remote_dir/" "true"; then
            if [[ "$QUIET" != "true" ]]; then
                echo -e "${GREEN}Nothing to commit${NC}"
            fi
            return
        fi
        
        get_changes "$local_dir/" "$USER@$HOST:$remote_dir/" "$QUIET"
        
        if confirm "Are you sure you want to commit those changes?"; then
            if [[ "$QUIET" != "true" ]]; then
                echo "Creating backup of server destination..."
            fi
            backup_create "$USER@$HOST:$remote_dir/" "lodestone"
            
            run_rsync_progress "$local_dir/" "$USER@$HOST:$remote_dir/"
            if [[ "$QUIET" != "true" ]]; then
                echo -e "${GREEN}Done!${NC}"
            fi
        else
            echo "Push cancelled."
        fi
    else
        if ! get_changes "$USER@$HOST:$remote_dir/" "$local_dir/" "true"; then
            if [[ "$QUIET" != "true" ]]; then
                echo -e "${GREEN}Nothing to commit${NC}"
            fi
            return
        fi
        
        get_changes "$USER@$HOST:$remote_dir/" "$local_dir/" "$QUIET"
        
        if confirm "Are you sure you want to commit those changes?"; then
            if [[ "$QUIET" != "true" ]]; then
                echo "Creating backup of local destination..."
            fi
            backup_create "$local_dir/" "lodestone"
            
            run_rsync_progress "$USER@$HOST:$remote_dir/" "$local_dir/"
            if [[ "$QUIET" != "true" ]]; then
                echo -e "${GREEN}Done!${NC}"
            fi
        else
            echo "Pull cancelled."
        fi
    fi
}

main() {
    parse_flags "$@"
    
    if [[ "$CMD_ACTION" == "init" ]]; then
        if [[ "$CMD_ARG" == "--reset" || -f "$CONFIG_FILE" ]]; then
            if [[ -f "$CONFIG_FILE" && "$CMD_ARG" != "--reset" ]]; then
                echo -e "${YELLOW}Config already exists at $CONFIG_FILE${NC}"
                echo -n "Overwrite? [y/N]: "
                read -r confirm
                if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
                    echo "Cancelled."
                    exit 0
                fi
            fi
        fi
        init_config
        exit 0
    fi
    
    load_config
    
    if [[ -z "$CMD_ACTION" ]]; then
        show_help
        exit 0
    fi
    
    case "$CMD_ACTION" in
        push)
            sync_push "${CMD_ARG:-}"
            ;;
        pull)
            sync_pull "${CMD_ARG:-}"
            ;;
        "$PUSH_CMD")
            sync_default "push"
            ;;
        "$PULL_CMD")
            sync_default "pull"
            ;;
        backup|backups)
            backup_list
            ;;
        restore)
            backup_restore "${CMD_ARG:-}"
            ;;
        *)
            echo -e "${RED}Unknown command: $CMD_ACTION${NC}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
